# Database
DATABASE_URL=postgresql+asyncpg://bazar:CHANGE_ME@db:5432/bazar_digital
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - ОБЯЗАТЕЛЬНО поменять на рандомную строку!
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS - указать домен фронтенда
CORS_ORIGINS=https://yourdomain.kz

# Production mode - OTP будет проверяться реально
DEV_MODE=false

# Server URL (для ссылок на файлы)
SERVER_URL=https://api.yourdomain.kz
